# MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    print("=" * 60)
    print("  STOCK PRICE PREDICTION — AI & ML Internship Project")
    print("=" * 60)

    # ── 1. Load data ──────────────────────────────────────────
    df_raw = fetch_stock_data(TICKER, START_DATE, END_DATE)

    # ── 2. Add indicators ─────────────────────────────────────
    df = add_technical_indicators(df_raw)

    # ── 3. Preprocess ─────────────────────────────────────────
    X_train, X_test, y_train, y_test, scaler_close, split_idx = preprocess(df)

    # ── 4. Train ──────────────────────────────────────────────
    model = train_model(X_train, y_train, X_test, y_test)

    # ── 5. Evaluate ───────────────────────────────────────────
    y_pred, y_true = evaluate_model(model, X_test, y_test, scaler_close)

    # ── 6. Visualize ──────────────────────────────────────────
    visualize(df, y_pred, y_true, split_idx)

    print("\n✓ Project complete.")
    print(f"  Prediction plot saved to: {PLOT_PATH}")


if __name__ == "__main__":
    main()
